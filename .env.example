# For local development, copy this file to .env and fill in the values.
# On Vercel, configure these values in Project Settings > Environment Variables.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_real_gemini_api_key_here"

# PORT: Optional local server port. Vercel manages ports automatically.
PORT=3000

# APP_URL: The URL where this app is hosted.
# Example: your-domain.com or project-name.vercel.app
APP_URL="salmanalhidamkara.site"
